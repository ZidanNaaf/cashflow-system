# Local environment and secrets
.env
.env.*
!.env.example

# Composer dependencies
vendor/

# Runtime data
writable/cache/*
writable/debugbar/*
writable/logs/*
writable/session/*
writable/uploads/*
!writable/**/index.html
!writable/.htaccess

# SQLite databases
writable/database/*.db
writable/database/*.sqlite
writable/database/*.sqlite3

# Uploaded public runtime files
public/uploads/*
!public/uploads/.htaccess
!public/uploads/index.html
!public/uploads/logos/
public/uploads/logos/*
!public/uploads/logos/index.html

# OS/editor files
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# Test and coverage output
coverage/
.phpunit.cache/
