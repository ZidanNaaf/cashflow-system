# Cashflow System environment example
# Copy this file to `.env`, then adjust values for your environment.

CI_ENVIRONMENT = production

# Local development:
app.baseURL = 'http://localhost:8080/'
app.forceGlobalSecureRequests = false
cookie.secure = false

# Production example:
# app.baseURL = 'https://your-domain.com/'
# app.forceGlobalSecureRequests = true
# cookie.secure = true

# Generate with:
# php spark key:generate
encryption.key =

# Default SQLite database location.
# You can leave this commented because the app already defaults to:
# writable/database/cashflow.db
# database.default.database = writable/database/cashflow.db
